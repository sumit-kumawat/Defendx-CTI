{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users with authentication and RBAC roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "viewer", "analyst"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Vulnerability": {
      "title": "Vulnerability",
      "description": "Cached or user-flagged vulnerability indicators",
      "type": "object",
      "properties": {
        "cveId": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string" },
        "score": { "type": "number" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "tags": { "type": "array" }
      },
      "required": ["cveId"]
    },
    "Alert": {
      "title": "Alert",
      "description": "User-configured threat alerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "query": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions"
    },
    "/vulnerabilities/{cveId}": {
      "schema": "Vulnerability",
      "description": "Global vulnerability reference"
    },
    "/users/{userId}/alerts/{alertId}": {
      "schema": "Alert",
      "description": "User-specific alerts"
    }
  }
}
